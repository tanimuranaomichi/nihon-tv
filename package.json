{
  "name": "nihon-tv",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,worker -c blue,green \"vite build --watch\" \"wrangler dev\"",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "deploy": "vite build && wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.1",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "vite": "^7.1.5",
    "wrangler": "^4.38.0"
  }
}

